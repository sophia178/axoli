# -----------------------------------------------------------------------
# Copy this file to .env.local and fill in every value before running.
# Lines marked REQUIRED must be set or the app will not start correctly.
# Lines marked OPTIONAL can be left blank to disable that feature locally.
# -----------------------------------------------------------------------

# --- Supabase (REQUIRED) -----------------------------------------------
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic / Claude (REQUIRED for AI generation) -------------------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe (OPTIONAL locally — required for payments) -----------------
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — only needed if testing Stripe webhooks via the CLI:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products/prices in the Stripe dashboard first
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
STRIPE_COINS_50_PRICE_ID=price_...
STRIPE_COINS_150_PRICE_ID=price_...
STRIPE_COINS_400_PRICE_ID=price_...
STRIPE_COINS_1000_PRICE_ID=price_...

# --- Google AdSense (OPTIONAL — ads are skipped if unset) --------------
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-...
NEXT_PUBLIC_ADSENSE_SLOT_ID=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT_ID=

# --- App URL (OPTIONAL locally) ----------------------------------------
# Set to http://localhost:3000 for local dev; used for absolute URL generation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Runtime (set automatically by Next.js / Vercel, safe to omit) -----
# NODE_ENV=development
# VERCEL_URL=
